---
import EditionLayout from "../../components/EditionLayout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";
import { formatFullDate } from "../../lib/dates";
import { getEditionsSorted, type Edition } from "../../lib/editions";
import { editionStructuredData } from "../../lib/structured-data";

export async function getStaticPaths() {
  const editions = await getEditionsSorted();
  return editions.map((edition, index) => ({
    params: { date: edition.id },
    // Ordinate dalla più recente: prev = più vecchia, next = più recente.
    props: {
      edition,
      prev: editions[index + 1],
      next: editions[index - 1],
    },
  }));
}

interface Props {
  edition: Edition;
  prev?: Edition | undefined;
  next?: Edition | undefined;
}

const { edition, prev, next } = Astro.props;
const strings = t();
const title = strings.edition.editionOf(formatFullDate(edition.data.date));
---

<BaseLayout
  title={title}
  description={edition.data.tldr}
  canonicalPath={`/edizioni/${edition.id}/`}
  structuredData={editionStructuredData(edition, Astro.site)}
>
  <EditionLayout edition={edition} prev={prev} next={next} />
</BaseLayout>
