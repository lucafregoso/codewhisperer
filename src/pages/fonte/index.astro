---
import MastHead from "../../components/MastHead.astro";
import TermIndex from "../../components/TermIndex.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";
import { getEmergentSources } from "../../lib/editions";

const strings = t();
const sources = await getEmergentSources();
---

<BaseLayout title={strings.filters.sources} canonicalPath="/fonte/">
  <MastHead />
  <main id="main">
    <header class="listing-header shell">
      <h1 class="listing-title">{strings.filters.sources}</h1>
      <hr class="section-rule" aria-hidden="true" />
    </header>
    <div class="shell">
      <TermIndex terms={sources} base="fonte" />
    </div>
  </main>
</BaseLayout>

<style>
  .listing-header {
    padding-block: var(--space-3) 0;
  }

  .listing-title {
    font-size: var(--text-hero);
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }
</style>
