---
import EditionLayout from "../components/EditionLayout.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { t } from "../i18n";
import { formatFullDate } from "../lib/dates";
import { getEditionsSorted } from "../lib/editions";
import { editionStructuredData } from "../lib/structured-data";

const strings = t();
const editions = await getEditionsSorted();
const edition = editions[0];
if (!edition) {
  throw new Error("Nessuna edizione in input/: impossibile costruire il sito");
}
const prev = editions[1];
const title = strings.edition.editionOf(formatFullDate(edition.data.date));
---

<BaseLayout
  title={title}
  description={site.meta.description}
  canonicalPath="/"
  structuredData={editionStructuredData(edition, Astro.site)}
>
  <EditionLayout edition={edition} prev={prev} />
</BaseLayout>
