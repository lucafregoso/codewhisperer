---
import { t } from "../i18n";
import type { Edition } from "../lib/editions";
import { formatFullDate } from "../lib/dates";
import { renderInline } from "../lib/md";
import CoverageFooter from "./CoverageFooter.astro";
import EditionNav from "./EditionNav.astro";
import MastHead from "./MastHead.astro";
import RadarRail from "./RadarRail.astro";
import SlowFeedFeature from "./SlowFeedFeature.astro";
import StoryCard from "./StoryCard.astro";

interface Props {
  edition: Edition;
  prev?: Edition | undefined;
  next?: Edition | undefined;
}

const { edition, prev, next } = Astro.props;
const strings = t();
const { stories, radar, slowFeed, coverage } = edition.data;

const sorted = [...stories].sort((a, b) => a.position - b.position);
const hero = sorted[0];
const leads = sorted.slice(1, 3);
const grid = sorted.slice(3);
---

<MastHead>
  <slot name="nav" slot="nav" />
</MastHead>

<main id="main" data-pagefind-body>
  <header class="edition-header shell">
    <h1 class="edition-date">
      {strings.edition.editionOf(formatFullDate(edition.data.date))}
    </h1>
    <p class="edition-tldr" set:html={renderInline(edition.data.tldr)} />
  </header>

  <div class="shell">
    <hr class="section-rule" aria-hidden="true" />
    <section class="front-page" aria-label={strings.edition.lead}>
      {hero && (
        <div class="front-hero">
          <StoryCard story={hero} variant="hero" />
        </div>
      )}
      {leads.length > 0 && (
        <div class="front-leads">
          {leads.map((story) => (
            <StoryCard story={story} variant="lead" />
          ))}
        </div>
      )}
    </section>

    {grid.length > 0 && (
      <>
        <hr class="section-rule" aria-hidden="true" />
        <section class="front-grid" aria-label={strings.edition.lead}>
          {grid.map((story) => (
            <StoryCard story={story} variant="grid" />
          ))}
        </section>
      </>
    )}
  </div>

  <div class="shell band">
    <RadarRail items={radar} />
  </div>

  {
    slowFeed && (
      <div class="shell">
        <SlowFeedFeature slowFeed={slowFeed} />
      </div>
    )
  }

  {
    coverage && (
      <div class="shell band">
        <CoverageFooter coverage={coverage} />
      </div>
    )
  }

  <EditionNav prev={prev} next={next} />
</main>

<style>
  .edition-header {
    padding-block: var(--space-3) var(--space-2);
  }

  .edition-date {
    font-size: var(--text-headline);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    margin: 0 0 var(--space-1);
  }

  .edition-tldr {
    font-size: var(--text-deck);
    color: var(--ink-muted);
    max-width: var(--measure);
    margin-bottom: 0;
  }

  .front-page {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-3);
    padding-block: var(--space-3);
  }

  .front-hero {
    grid-column: span 8;
  }

  .front-leads {
    grid-column: span 4;
    display: grid;
    gap: var(--space-3);
    align-content: start;
    border-left: 1px solid var(--hairline);
    padding-left: var(--space-3);
  }

  .front-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    padding-block: var(--space-3);
  }

  .front-grid > :global(.story:not(:first-child)) {
    border-left: 1px solid var(--hairline);
    padding-left: var(--space-3);
  }

  .band {
    margin-block: var(--space-3);
  }

  @media (max-width: 56rem) {
    .front-page {
      grid-template-columns: 1fr;
    }

    .front-hero,
    .front-leads {
      grid-column: auto;
    }

    .front-leads {
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid var(--hairline);
      padding-top: var(--space-3);
    }

    .front-grid {
      grid-template-columns: 1fr;
    }

    .front-grid > :global(.story:not(:first-child)) {
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid var(--hairline);
      padding-top: var(--space-3);
    }
  }
</style>
