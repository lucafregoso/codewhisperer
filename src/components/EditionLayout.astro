---
import { t } from "../i18n";
import type { Edition } from "../lib/editions";
import { formatFullDate } from "../lib/dates";
import { renderInline } from "../lib/md";
import { assetSrc, withBase } from "../lib/url";
import CoverageFooter from "./CoverageFooter.astro";
import EditionNav from "./EditionNav.astro";
import MastHead from "./MastHead.astro";
import PodcastPlayer from "./PodcastPlayer.astro";
import RadarRail from "./RadarRail.astro";
import SlowFeedFeature from "./SlowFeedFeature.astro";
import StoryCard from "./StoryCard.astro";

interface Props {
  edition: Edition;
  prev?: Edition | undefined;
  next?: Edition | undefined;
}

const { edition, prev, next } = Astro.props;
const strings = t();
const { stories, radar, slowFeed, coverage, podcast } = edition.data;

const sorted = [...stories].sort((a, b) => a.position - b.position);
const hero = sorted[0];
const leads = sorted.slice(1, 3);
const index = sorted.slice(3);
---

<MastHead>
  <slot name="nav" slot="nav" />
</MastHead>

<main id="main" data-pagefind-body>
  <header class="edition-header shell">
    <div class="edition-meta">
      <h1 class="edition-date">
        <span class="edition-mark" aria-hidden="true"></span>
        {strings.edition.editionOf(formatFullDate(edition.data.date))}
      </h1>
      {
        (prev || next) && (
          <nav class="edition-jump" aria-label={strings.nav.editions}>
            {prev && (
              <a
                class="edition-jump-link"
                href={withBase(`/edizioni/${prev.id}/`)}
              >
                ← {formatFullDate(prev.data.date)}
              </a>
            )}
            {next && (
              <a
                class="edition-jump-link"
                href={withBase(`/edizioni/${next.id}/`)}
              >
                {formatFullDate(next.data.date)} →
              </a>
            )}
          </nav>
        )
      }
    </div>
    <p class="edition-tldr" set:html={renderInline(edition.data.tldr)} />
    {
      podcast && (
        <PodcastPlayer
          src={withBase(`/podcast/${encodeURIComponent(podcast.file)}`)}
        />
      )
    }
    {
      edition.data.image && (
        <figure class="edition-cover">
          <img
            src={assetSrc(edition.data.image.url)}
            alt={
              edition.data.image.alt ??
              strings.edition.editionOf(formatFullDate(edition.data.date))
            }
            loading="eager"
            decoding="async"
          />
        </figure>
      )
    }
  </header>

  <div class="shell">
    <hr class="section-rule" aria-hidden="true" />
    <div class="front">
      {hero && (
        <section class="front-hero" aria-label={strings.edition.lead}>
          <StoryCard story={hero} variant="hero" />
        </section>
      )}
      {leads.length > 0 && (
        <div class="front-leads">
          {leads.map((story) => (
            <StoryCard story={story} variant="lead" />
          ))}
        </div>
      )}
      {index.length > 0 && (
        <section class="front-index" aria-label={strings.edition.index}>
          {index.map((story) => (
            <StoryCard story={story} variant="index" />
          ))}
        </section>
      )}
    </div>
  </div>

  <div class="shell band">
    <RadarRail items={radar} />
  </div>

  {
    slowFeed && (
      <div class="shell">
        <SlowFeedFeature slowFeed={slowFeed} />
      </div>
    )
  }

  {
    coverage && (
      <div class="shell band">
        <CoverageFooter coverage={coverage} />
      </div>
    )
  }

  <EditionNav prev={prev} next={next} />
</main>

<style>
  .edition-header {
    padding-block: var(--space-2) var(--space-2);
  }

  .edition-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
    margin-bottom: var(--space-2);
  }

  .edition-date {
    font-size: var(--text-title);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin: 0;
  }

  .edition-mark {
    inline-size: 0.62em;
    block-size: 0.62em;
    background: var(--signal);
    flex: none;
  }

  .edition-jump {
    display: flex;
    gap: var(--space-2);
  }

  .edition-jump-link {
    font-family: var(--font-display);
    font-size: var(--text-body-sm);
    font-weight: 700;
    text-decoration: none;
    color: var(--ink-muted);
  }

  .edition-jump-link:hover {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--signal-ink);
    text-decoration-thickness: 2px;
  }

  .edition-tldr {
    font-size: var(--text-deck);
    color: var(--ink-muted);
    max-width: var(--measure);
    margin-bottom: 0;
    text-wrap: pretty;
  }

  .edition-cover {
    margin: var(--space-2) 0 0;
  }

  .edition-cover img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  /* Un solo grid ad aree: l'indice risale sotto l'hero, i lead
     corrono in colonna a fianco — niente buchi (spec 012), ordine
     di lettura DOM invariato (1, 2-3, 4+). */
  .front {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
    grid-template-rows: auto 1fr;
    grid-template-areas:
      "hero leads"
      "index leads";
    column-gap: var(--space-3);
    padding-block: var(--space-3);
  }

  .front-hero {
    grid-area: hero;
    padding-bottom: var(--space-3);
  }

  .front-leads {
    grid-area: leads;
    display: grid;
    gap: var(--space-3);
    align-content: start;
    border-left: 1px solid var(--hairline);
    padding-left: var(--space-3);
  }

  .front-index {
    grid-area: index;
    align-self: start;
  }

  .band {
    margin-block: var(--space-3);
  }

  @media (max-width: 56rem) {
    .front {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-template-areas:
        "hero"
        "leads"
        "index";
    }

    .front-leads {
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid var(--hairline);
      padding-top: var(--space-3);
      padding-bottom: var(--space-3);
    }
  }
</style>
