---
import { site } from "../data/site";
import { t } from "../i18n";
import { withBase } from "../lib/url";
import ThemeToggle from "./ThemeToggle.astro";

const strings = t();
---

<header class="masthead">
  <div class="masthead-bar shell">
    <a class="brand" href={withBase("/")}>{site.name}</a>
    <nav class="masthead-nav" aria-label={strings.nav.home}>
      {
        [
          { href: "/edizioni/", label: strings.nav.editions },
          { href: "/categoria/", label: strings.nav.categories },
          { href: "/fonte/", label: strings.nav.sources },
          { href: "/cerca/", label: strings.nav.search },
        ].map(({ href, label }) => (
          <a
            class="masthead-link kicker"
            href={withBase(href)}
            aria-current={
              Astro.url.pathname === withBase(href) ? "page" : undefined
            }
          >
            {label}
          </a>
        ))
      }
      <slot name="nav" />
      <ThemeToggle />
    </nav>
  </div>
  <div class="shell">
    <span class="signal-bar" aria-hidden="true"></span>
  </div>
  <hr class="section-rule" aria-hidden="true" />
</header>

<style>
  .masthead-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
    padding-block: var(--space-2);
  }

  @media (max-width: 48rem) {
    .masthead-nav {
      flex-basis: 100%;
      overflow-x: auto;
      scrollbar-width: none;
      padding-bottom: var(--space-1);
    }
  }

  .brand {
    font-family: var(--font-display);
    font-variation-settings: "wdth" var(--display-width);
    font-weight: var(--display-weight);
    font-size: var(--text-title);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .masthead-nav {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .masthead-link {
    text-decoration: none;
  }

  .masthead-link:hover,
  .masthead-link[aria-current="page"] {
    text-decoration: underline;
    text-decoration-color: var(--signal-ink);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  /* La firma di testata: barra segnale corta sotto il nameplate. */
  .signal-bar {
    display: block;
    inline-size: clamp(4rem, 12vw, 7rem);
    block-size: var(--rule-weight);
    background: var(--signal);
  }
</style>
