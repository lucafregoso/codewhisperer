---
import { site } from "../data/site";
import { t } from "../i18n";
import { withBase } from "../lib/url";
import ThemeToggle from "./ThemeToggle.astro";

const strings = t();
---

<header class="masthead">
  <div class="masthead-bar shell">
    <a class="brand" href={withBase("/")}>{site.name}</a>
    <nav class="masthead-nav" aria-label={strings.nav.home}>
      <slot name="nav" />
      <ThemeToggle />
    </nav>
  </div>
  <hr class="section-rule" aria-hidden="true" />
</header>

<style>
  .masthead-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding-block: var(--space-2);
  }

  .brand {
    font-family: var(--font-display);
    font-variation-settings: "wdth" var(--display-width);
    font-weight: var(--display-weight);
    font-size: var(--text-title);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .masthead-nav {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
</style>
