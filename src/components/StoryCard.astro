---
import { t } from "../i18n";
import type { Story } from "../lib/editions";
import { renderInline } from "../lib/md";
import { assetSrc } from "../lib/url";
import SourceBadge from "./SourceBadge.astro";

interface Props {
  story: Story;
  variant: "hero" | "lead" | "index";
}

const { story, variant } = Astro.props;
const strings = t();
const bodyHtml = renderInline(story.body);
const HeadingTag = variant === "hero" ? "h2" : "h3";
const image = story.image;
const imageAlt = image?.alt ?? story.title;
---

<article class:list={["story", `story--${variant}`]}>
  <span class="story-no" aria-hidden="true">{story.position}</span>

  {
    variant === "index" && image && (
      <img
        class="story-thumb"
        src={assetSrc(image.url)}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
      />
    )
  }

  <div class="story-main">
    {
      variant === "lead" && image && (
        <img
          class="story-image"
          src={assetSrc(image.url)}
          alt={imageAlt}
          loading="lazy"
          decoding="async"
        />
      )
    }
    <HeadingTag class="story-title" id={story.slug}>
      <a class="story-anchor" href={`#${story.slug}`}>{story.title}</a>
    </HeadingTag>
    {
      variant === "hero" && image && (
        <img
          class="story-image"
          src={assetSrc(image.url)}
          alt={imageAlt}
          loading="eager"
          decoding="async"
        />
      )
    }
    <p class="story-body" set:html={bodyHtml} />
    <footer class="story-sources">
      <span class="sr-only">{strings.edition.sources}:</span>
      <ul class="source-list" role="list">
        {story.sources.map((source) => (
          <li>
            <SourceBadge source={source} />
          </li>
        ))}
      </ul>
    </footer>
  </div>
</article>

<style>
  .story {
    min-inline-size: 0;
  }

  .story-no {
    font-family: var(--font-display);
    font-variation-settings: "wdth" var(--display-width);
    font-weight: var(--display-weight);
    color: var(--signal-ink);
    line-height: 0.82;
    user-select: none;
  }

  .story-title {
    scroll-margin-top: var(--space-4);
    margin-block: 0 var(--space-1);
  }

  .story-anchor {
    text-decoration: none;
  }

  .story-anchor:hover {
    text-decoration: underline;
    text-decoration-color: var(--signal-ink);
    text-decoration-thickness: var(--rule-weight);
  }

  /* L'arte del pezzo esiste solo se l'edizione la fornisce:
     nessuno slot riservato, nessuna decorazione generata. */
  .story-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin-block: var(--space-1) var(--space-2);
  }

  .story-thumb {
    width: 5.5rem;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    margin-top: 0.3rem;
    order: -1;
  }

  .story-body {
    margin-block: var(--space-1) var(--space-1);
  }

  .source-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-1) var(--space-1);
  }

  /* Nel contesto storia le fonti sono un sussurro: peso normale,
     faint, separatore tipografico. Il badge pieno vive su /fonte/. */
  .source-list :global(.source-badge) {
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--ink-faint);
    border-bottom-color: transparent;
  }

  .source-list :global(.source-badge:hover) {
    color: var(--ink);
    border-bottom-color: var(--signal-ink);
  }

  .source-list li:not(:last-child)::after {
    content: "·";
    color: var(--ink-faint);
    margin-left: var(--space-1);
  }

  /* ── Rango 1: hero ─────────────────────────────────────────── */
  .story--hero {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-1) var(--space-2);
    align-items: start;
  }

  .story--hero .story-no {
    font-size: var(--text-hero);
  }

  .story--hero .story-title {
    font-size: var(--text-hero);
    letter-spacing: -0.01em;
  }

  .story--hero .story-body {
    font-size: var(--text-deck);
  }

  /* ── Ranghi 2-3: lead ──────────────────────────────────────── */
  .story--lead {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-1) var(--space-2);
    align-items: start;
  }

  .story--lead .story-no {
    font-size: var(--text-headline);
  }

  .story--lead .story-title {
    font-size: var(--text-headline);
  }

  .story--lead .story-body,
  .story--lead .story-sources {
    font-size: var(--text-body-sm);
  }

  .story--lead .story-body {
    color: var(--ink-muted);
  }

  /* ── Ranghi 4+: riga d'indice da quotidiano ────────────────── */
  .story--index {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-1) var(--space-2);
    align-items: start;
    padding-block: var(--space-2);
    border-top: 1px solid var(--hairline);
    transition: background-color 160ms var(--ease-out);
  }

  /* La colonna thumbnail esiste solo quando l'immagine c'è. */
  .story--index:has(.story-thumb) {
    grid-template-columns: auto auto 1fr;
  }

  .story--index:hover {
    background-color: var(--signal-surface);
  }

  /* In hover il fondo diventa signal-surface: il faint scala a muted
     per restare AA (4.5:1 su testo piccolo). */
  .story--index:hover .source-list :global(.source-badge) {
    color: var(--ink-muted);
  }

  .story--index:hover .source-list li:not(:last-child)::after {
    color: var(--ink-muted);
  }

  .story--index .story-no {
    font-size: var(--text-title);
    min-width: 1.6ch;
    text-align: right;
  }

  .story--index .story-title {
    font-size: var(--text-title);
  }

  .story--index .story-body {
    font-size: var(--text-body-sm);
    color: var(--ink-muted);
    margin-block: var(--space-1) var(--space-1);
  }

  @media (max-width: 48rem) {
    .story--index .story-thumb {
      display: none;
    }

    /* :has() matcha sul DOM, non sulla visibilità: senza questo
       reset la thumb nascosta lascerebbe una colonna fantasma. */
    .story--index:has(.story-thumb) {
      grid-template-columns: auto 1fr;
    }
  }
</style>
