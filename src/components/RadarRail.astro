---
import { t } from "../i18n";
import type { RadarItem } from "../lib/editions";
import { renderInline } from "../lib/md";
import SourceBadge from "./SourceBadge.astro";

interface Props {
  items: RadarItem[];
}

const { items } = Astro.props;
const strings = t();
---

{
  items.length > 0 && (
    <section class="radar full-bleed" aria-labelledby="radar-title">
      <h2 class="radar-title" id="radar-title">
        {strings.edition.radar}
        <span class="radar-count" aria-hidden="true">{items.length}</span>
      </h2>
      <ul class="radar-list" role="list">
        {items.map((item) => (
          <li class="radar-item">
            <p class="radar-text" set:html={renderInline(item.text)} />
            <SourceBadge source={item.source} />
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .radar {
    padding-block: var(--space-3);
  }

  /* La banda Radar è il territorio del segnale. */
  .radar.full-bleed::before {
    background: var(--signal-surface);
    border-top-color: var(--signal);
  }

  .radar-title {
    font-size: var(--text-headline);
    text-transform: uppercase;
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
    margin: 0 0 var(--space-2);
  }

  .radar-count {
    color: var(--signal);
    font-size: var(--text-title);
  }

  .radar-list {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 1;
    column-gap: var(--space-4);
    column-rule: 1px solid var(--hairline);
  }

  .radar-item {
    break-inside: avoid;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-2);
  }

  @media (min-width: 56rem) {
    .radar-list {
      columns: 2;
    }
  }

  .radar-text {
    font-size: var(--text-body-sm);
    margin-bottom: var(--space-1);
  }

  /* Su signal-surface il faint non regge AA (4.29:1): si promuove
     a muted (8.3:1) l'attribuzione via dentro la banda. */
  .radar :global(.source-via) {
    color: var(--ink-muted);
  }
</style>
